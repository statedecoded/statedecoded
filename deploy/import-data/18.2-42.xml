<law>
	<structure>
		<unit label="title" identifier="18.2" level="1">Crimes and Offenses Generally</unit>
		<unit label="chapter" identifier="4" level="2">Crimes Against the Person</unit>
		<unit label="article" identifier="2" level="3">Crimes by Mobs</unit>
	</structure>
	<section_number>18.2-42</section_number>
	<catch_line>Assault or battery by mob</catch_line>
	<text>
		Any and every person composing a mob which shall commit a simple assault or battery shall be guilty of a Class 1 misdemeanor.
	</text>
	<history>Code 1950, § 18.1-31; 1960, c. 358; 1975, cc. 14, 15.</history>
</law>
