<law>
	<structure>
		<unit label="title" identifier="18.2" level="1">Crimes and Offenses Generally</unit>
		<unit label="chapter" identifier="1" level="2">In General</unit>
		<unit label="article" identifier="2" level="3">Construction and Definitions</unit>
