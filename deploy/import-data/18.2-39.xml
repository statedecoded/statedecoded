<?xml version="1.0" encoding="utf-8"?>
<law>
	<structure>
		<unit label="title" identifier="18.2" level="1">Crimes and Offenses Generally</unit>
		<unit label="chapter" identifier="4" level="2">Crimes Against the Person</unit>
		<unit label="article" identifier="2" level="3">Crimes by Mobs</unit>
	</structure>
	<section_number>18.2-39</section_number>
	<catch_line>"Lynching" defined</catch_line>
	<text>
		Any act of violence by a mob upon the body of any person, which shall result in the death of such person, shall constitute a "lynching."
	</text>
	<history>Code 1950, § 18.1-28; 1960, c. 358; 1975, cc. 14, 15.</history>
</law>
