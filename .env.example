# Copy this file to .env before running `docker compose up`.
# Values shown are the defaults — edit only what you need to change.

# MySQL credentials (used by both app and db containers)
MYSQL_USER=statedecoded
MYSQL_PASSWORD=statedecoded
MYSQL_ROOT_PASSWORD=rootpassword

# Admin panel credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Site identity (optional — sensible defaults are baked in)
# SITE_TITLE=The State Decoded
# PLACE_NAME=State
# LAWS_NAME=Code of State

# Search engine (SqlSearchEngine is the only supported option in Docker)
SEARCH_ENGINE=SqlSearchEngine

# Memcached (only needed when running `--profile cache`)
# CACHE_HOST=memcached
# CACHE_PORT=11211

# Debug verbosity: 1 (verbose) to 10 (quiet)
DEBUG_LEVEL=5
